datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique @db.VarChar(255)
  password     String    @db.VarChar(500)
  name         String    @db.VarChar(255)
  role         String    @default("STUDENT") @db.VarChar(20)
  status       String    @default("ACTIVE") @db.VarChar(20)
  avatarUrl    String?   @db.VarChar(500)
  phone        String?   @db.VarChar(20)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  lastActiveAt DateTime?

  adminProfile    AdminProfile?
  lecturerProfile LecturerProfile?
  studentProfile  StudentProfile?
  sessions        Session[]
  createdExams    Exam[]           @relation("ExamCreator")
  announcements   Announcement[]   @relation("AnnouncementAuthor")
  auditLogs       AuditLog[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("Users")
}

model Course {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(200)
  code        String   @unique @db.VarChar(50)
  description String?  @db.Text
  credits     Int?
  department  String?  @db.VarChar(100)
  semester    Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  announcements Announcement[]
  exams         Exam[]

  @@index([code])
  @@map("courses")
}

model Announcement {
  id             String    @id @default(cuid())
  title          String    @db.VarChar(255)
  content        String    @db.Text
  type           String    @db.VarChar(20)
  targetAudience String    @db.VarChar(30)
  courseId       String?   @map("course_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  expiresAt      DateTime? @map("expires_at")
  createdBy      String    @map("created_by")
  isActive       Boolean   @default(true) @map("is_active")

  course Course? @relation(fields: [courseId], references: [id])
  author User    @relation("AnnouncementAuthor", fields: [createdBy], references: [id])

  @@map("announcements")
}

model StudentProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  studentId        String   @unique @db.VarChar(50)
  rollNumber       String?  @db.VarChar(50)
  department       String   @db.VarChar(100)
  program          String   @db.VarChar(100)
  batch            Int
  semester         Int
  admissionYear    Int
  totalExamsTaken  Int      @default(0)
  completedExams   Int      @default(0)
  averageScore     Float    @default(0)
  totalViolations  Int      @default(0)
  rank             Int?
  emergencyContact String?  @db.VarChar(20)
  address          String?  @db.Text
  metaData         String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("StudentProfiles")
}

model LecturerProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  employeeId        String   @unique @db.VarChar(50)
  department        String   @db.VarChar(100)
  faculty           String   @db.VarChar(100)
  designation       String   @db.VarChar(100)
  qualification     String?  @db.VarChar(200)
  specialization    String?  @db.VarChar(200)
  totalExamsCreated Int      @default(0)
  activeExams       Int      @default(0)
  totalStudents     Int      @default(0)
  averageRating     Float    @default(0)
  officeHours       String?  @db.Text
  officeLocation    String?  @db.VarChar(200)
  officePhone       String?  @db.VarChar(20)
  website           String?  @db.VarChar(500)
  metaData          String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("LecturerProfiles")
}

model AdminProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  permissions         String   @default("[]") @db.Text
  accessLevel         Int      @default(1)
  adminType           String   @default("SUPER_ADMIN") @db.VarChar(50)
  assignedDepartments String?  @db.Text
  metaData            String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AdminProfiles")
}

model Session {
  id             String   @id @default(uuid())
  userId         String
  sessionToken   String   @unique @db.VarChar(500)
  expires        DateTime
  ipAddress      String?  @db.VarChar(45)
  userAgent      String?  @db.VarChar(500)
  deviceInfo     String?  @db.Text
  isActive       Boolean  @default(true)
  lastActivityAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("Sessions")
}

model Exam {
  id              String    @id @default(uuid())
  title           String    @db.VarChar(500)
  description     String?   @db.Text
  code            String    @unique @db.VarChar(20)
  shortCode       String    @unique @db.VarChar(10)
  lecturerId      String
  courseCode      String    @db.VarChar(50)
  courseName      String    @db.VarChar(200)
  duration        Int
  totalMarks      Int
  passingMarks    Int
  startTime       DateTime
  endTime         DateTime
  resultPublishAt DateTime?
  status          String    @default("DRAFT") @db.VarChar(20)
  isPublished     Boolean   @default(false)
  isArchived      Boolean   @default(false)
  settings        String?   @db.Text
  instructions    String?   @db.Text
  allowedDevices  String?   @db.Text
  maxAttempts     Int       @default(1)
  securityLevel   Int       @default(1)
  proctoringMode  String    @default("NONE") @db.VarChar(50)
  totalAttempts   Int       @default(0)
  avgScore        Float?    @default(0)
  passRate        Float?    @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publishedAt     DateTime?

  lecturer   User            @relation("ExamCreator", fields: [lecturerId], references: [id])
  course     Course          @relation(fields: [courseCode], references: [code])
  attempts   ExamAttempt[]
  examLogs   ExamLog[]
  violations ExamViolation[]
  questions  Question[]

  @@index([lecturerId])
  @@index([code])
  @@index([status])
  @@map("Exams")
}

model Question {
  id            String   @id @default(uuid())
  examId        String
  questionText  String   @db.Text
  questionType  String   @default("MULTIPLE_CHOICE") @db.VarChar(30)
  marks         Int      @default(1)
  order         Int      @default(0)
  difficulty    Int      @default(1)
  options       String?  @db.Text
  correctAnswer String?  @db.Text
  explanation   String?  @db.Text
  imageUrl      String?  @db.VarChar(500)
  audioUrl      String?  @db.VarChar(500)
  videoUrl      String?  @db.VarChar(500)
  tags          String?  @db.Text
  category      String?  @db.VarChar(100)
  topic         String?  @db.VarChar(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  exam    Exam     @relation(fields: [examId], references: [id])
  answers Answer[]

  @@index([examId])
  @@map("Questions")
}

model ExamAttempt {
  id                String    @id @default(uuid())
  examId            String
  studentId         String
  attemptNumber     Int       @default(1)
  startedAt         DateTime  @default(now())
  submittedAt       DateTime?
  timeSpent         Int       @default(0)
  status            String    @default("NOT_STARTED") @db.VarChar(20)
  score             Float?
  totalMarks        Int
  percentage        Float?
  grade             String?   @db.VarChar(10)
  rank              Int?
  ipAddress         String?   @db.VarChar(45)
  userAgent         String?   @db.VarChar(500)
  deviceInfo        String?   @db.Text
  browserInfo       String?   @db.Text
  violationCount    Int       @default(0)
  isFlagged         Boolean   @default(false)
  isTerminated      Boolean   @default(false)
  terminationReason String?   @db.VarChar(500)
  proctoringData    String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  exam    Exam     @relation(fields: [examId], references: [id])
  answers Answer[]

  @@unique([examId, studentId, attemptNumber])
  @@index([examId])
  @@index([studentId])
  @@map("ExamAttempts")
}

model Answer {
  id              String    @id @default(uuid())
  attemptId       String
  questionId      String
  answerText      String?   @db.Text
  selectedOptions String?   @db.Text
  isCorrect       Boolean?
  marksAwarded    Float     @default(0)
  feedback        String?   @db.Text
  autoGraded      Boolean   @default(false)
  timeSpent       Int?
  answeredAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  attempt  ExamAttempt @relation(fields: [attemptId], references: [id], onUpdate: NoAction)
  question Question    @relation(fields: [questionId], references: [id], onUpdate: NoAction)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("Answers")
}

model ExamViolation {
  id            String   @id @default(uuid())
  examId        String
  studentId     String
  attemptId     String?
  violationType String   @db.VarChar(30)
  description   String   @db.Text
  severity      String   @default("MEDIUM") @db.VarChar(20)
  evidence      String?  @db.Text
  actionTaken   String?  @db.VarChar(100)
  isReviewed    Boolean  @default(false)
  reviewedBy    String?
  reviewNotes   String?  @db.Text
  timestamp     DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([studentId])
  @@map("ExamViolations")
}

model ExamLog {
  id        String   @id @default(uuid())
  examId    String
  attemptId String?
  studentId String?
  action    String   @db.VarChar(100)
  details   String?  @db.Text
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.VarChar(500)
  timestamp DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@map("ExamLogs")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  examId      String?
  type        String    @db.VarChar(30)
  title       String    @db.VarChar(200)
  message     String    @db.Text
  data        String?   @db.Text
  status      String    @default("UNREAD") @db.VarChar(20)
  isImportant Boolean   @default(false)
  isArchived  Boolean   @default(false)
  actionUrl   String?   @db.VarChar(500)
  actionLabel String?   @db.VarChar(100)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  readAt      DateTime?

  @@index([userId])
  @@index([type])
  @@map("Notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   @db.VarChar(100)
  details    String?  @db.Text
  entityType String?  @db.VarChar(100)
  entityId   String?  @db.VarChar(255)
  metadata   String?  @db.Text
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("AuditLogs")
}

model Message {
  id          String    @id @default(uuid())
  senderId    String
  recipientId String
  subject     String?   @db.VarChar(200)
  content     String    @db.Text
  attachments String?   @db.Text
  isRead      Boolean   @default(false)
  isArchived  Boolean   @default(false)
  isImportant Boolean   @default(false)
  parentId    String?
  threadId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  readAt      DateTime?

  @@index([senderId])
  @@index([recipientId])
  @@map("Messages")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  description String?  @db.VarChar(500)
  category    String   @db.VarChar(50)
  isPublic    Boolean  @default(false)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("SystemSettings")
}